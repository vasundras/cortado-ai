# Cortado AI - Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
GOOGLE_API_KEY=your-gemini-api-key-here

# Google Cloud Project ID (required for Cloud Run deployment)
GCP_PROJECT_ID=cortado-ai

# Agent model configuration
# Default: gemini-2.5-flash-native-audio-preview-12-2025 (native audio, voice mode)
# Alternative: gemini-2.5-flash (half-cascade, text mode)
CORTADO_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Server configuration
HOST=0.0.0.0
PORT=8080
